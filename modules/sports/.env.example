SPORTS_FEED_PORT=8097
SPORTS_FEED_INTERNAL_PORT=8080
SPORTS_FEED_CONTAINER_NAME=atlas-sports-feed
SPORTS_CONFIG_DIR=/mnt/storage/configs/sportyfin
SPORTS_MEDIA_DIR=/mnt/storage/media/Sports

SPORTS_POSTGAME_GRACE_MINUTES=15
SPORTS_PREGAME_WINDOW_MINUTES=60
SPORTS_DISCOVERY_DAYS_AHEAD=1
SPORTS_CONTROLLER_INTERVAL_SECONDS=30
SPORTS_PROVIDER_HEALTH_FILE=/mnt/storage/configs/sportyfin/state/provider-health.json
SPORTS_CONTROLLER_HEARTBEAT_FILE=/mnt/storage/configs/sportyfin/state/controller-heartbeat
SPORTS_SUBSCRIPTIONS_FILE=/mnt/storage/configs/sportyfin/state/subscriptions.json

# Sports provider
SPORTS_PROVIDER=thesportsdb
SPORTS_PROVIDER_TIMEOUT_SECONDS=15

# TheSportsDB
SPORTS_THESPORTSDB_API_KEY=123
SPORTS_THESPORTSDB_LEAGUE_IDS=

# Sports recording planner
SPORTS_RECORDINGS_FILE=/mnt/storage/configs/sportyfin/recordings/recordings.json
SPORTS_RECORDING_PREROLL_MINUTES=5
SPORTS_RECORDING_POSTROLL_MINUTES=15

# Sports recording runtime
SPORTS_RECORDING_LOG_DIR=/mnt/storage/configs/sportyfin/logs/recordings
SPORTS_FAKE_RECORDER_SECONDS=300

SPORTS_RECORDER_MODE=ffmpeg
SPORTS_FFMPEG_BINARY=ffmpeg
SPORTS_FFMPEG_LOG_LEVEL=warning

# Sports scheduled state and artifact maintenance
SPORTS_MAINTENANCE_ENABLED=true
SPORTS_MAINTENANCE_INTERVAL_SECONDS=3600
SPORTS_MAINTENANCE_DRY_RUN=false
SPORTS_MAINTENANCE_STATE_FILE=/mnt/storage/configs/sportyfin/state/maintenance.json
SPORTS_TASK_SCHEDULER_STATE_FILE=/mnt/storage/configs/atlas/runtime/scheduler/sports.json
SPORTS_PARTIAL_RETENTION_HOURS=6
SPORTS_RECORDING_LOG_RETENTION_DAYS=14
SPORTS_RECORDING_EXIT_RETENTION_DAYS=7
SPORTS_RECORDING_METADATA_RETENTION_DAYS=30
