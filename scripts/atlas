#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="/opt/project-atlas"
ATLAS_CONFIG_FILE="$PROJECT_DIR/config/atlas.conf"
ATLAS_MODULE_CONFIG_FILE="$PROJECT_DIR/config/modules/modules.conf"

if [[ ! -f "$ATLAS_CONFIG_FILE" ]]; then
  echo "Missing Atlas config: $ATLAS_CONFIG_FILE"
  exit 1
fi

source "$ATLAS_CONFIG_FILE"

if [[ -f "$ATLAS_MODULE_CONFIG_FILE" ]]; then
  source "$ATLAS_MODULE_CONFIG_FILE"
fi

cd "$ATLAS_PROJECT_DIR"

command="${1:-help}"

print_header() {
  echo "Project Atlas"
  echo "Simplicity Meets Ingenuity"
  echo
}

case "$command" in
  help)
    print_header
    cat <<'HELP'
Usage:
  atlas <command> [options]

Core Commands
-------------
  atlas help
  atlas version
  atlas status
  atlas services
  atlas urls
  atlas git

Modules
-------
  atlas modules
  atlas module list
  atlas module status <module>
  atlas module verify <module>
  atlas module doctor <module>

Maintenance
-----------
  atlas verify
  atlas doctor
  atlas update
  atlas backup
  atlas restart
  atlas logs <container>

Intelligence
------------
  atlas ari collect
  atlas ari report
HELP
    ;;

  version)
    print_header
    echo -n "Version: "
    cat VERSION 2>/dev/null || echo "unknown"
    echo "Branch:  $(git branch --show-current 2>/dev/null || echo unknown)"
    ;;

  status)
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
    ;;

  services)
    docker compose ps
    ;;

  urls)
    source .env
    cat <<URLS
Homepage:      http://${LXC_IP}:3000
Jellyfin:      http://${LXC_IP}:8096
Jellyseerr:    http://${LXC_IP}:5055
Sonarr:        http://${LXC_IP}:8989
Sonarr Anime:  http://${LXC_IP}:8990
Radarr:        http://${LXC_IP}:7878
Radarr Anime:  http://${LXC_IP}:7879
Prowlarr:      http://${LXC_IP}:9696
qBittorrent:   http://${LXC_IP}:8080
Bazarr:        http://${LXC_IP}:6767
Maintainerr:   http://${LXC_IP}:6246
Tautulli:      http://${LXC_IP}:8181
Dozzle:        http://${LXC_IP}:9999
URLS
    ;;

  git)
    git status
    ;;

  modules)
    print_header
    echo "Atlas Modules"
    echo
    echo "Sports:"
    echo "  Name:    ${ATLAS_MODULE_SPORTS_NAME:-Sports Platform}"
    echo "  Enabled: ${ATLAS_MODULE_SPORTS_ENABLED:-false}"
    echo "  Compose: ${ATLAS_MODULE_SPORTS_COMPOSE_FILE:-docker-compose.sports.yml}"
    echo "  Docs:    ${ATLAS_MODULE_SPORTS_DOC:-docs/SPORTS.md}"
    ;;

  module)
    subcommand="${2:-list}"
    module_name="${3:-sports}"

    case "$subcommand" in
      list)
        print_header
        echo "Atlas Module List"
        echo
        echo "sports  ${ATLAS_MODULE_SPORTS_ENABLED:-false}  ${ATLAS_MODULE_SPORTS_NAME:-Sports Platform}"
        ;;

      status)
        case "$module_name" in
          sports)
            print_header
            echo "Sports Module"
            echo
            echo "Name:         ${ATLAS_MODULE_SPORTS_NAME:-Sports Platform}"
            echo "Enabled:      ${ATLAS_MODULE_SPORTS_ENABLED:-false}"
            echo "Compose File: ${ATLAS_MODULE_SPORTS_COMPOSE_FILE:-docker-compose.sports.yml}"
            echo "Docs:         ${ATLAS_MODULE_SPORTS_DOC:-docs/SPORTS.md}"

            if [[ -f "$ATLAS_PROJECT_DIR/${ATLAS_MODULE_SPORTS_COMPOSE_FILE:-docker-compose.sports.yml}" ]]; then
              echo "Compose:      present"
            else
              echo "Compose:      missing"
            fi

            if [[ -f "$ATLAS_PROJECT_DIR/${ATLAS_MODULE_SPORTS_DOC:-docs/SPORTS.md}" ]]; then
              echo "Docs:         present"
            else
              echo "Docs:         missing"
            fi
            ;;
          *)
            echo "Unknown module: $module_name"
            exit 1
            ;;
        esac
        ;;

      verify)
        if [[ "$module_name" != "sports" ]]; then
          echo "Usage: atlas module verify sports"
          exit 1
        fi

        print_header
        echo "Sports Module Verification"
        echo

        pass=true

        check_module() {
          label="$1"
          shift
          if "$@" >/dev/null 2>&1; then
            echo "OK   $label"
          else
            echo "FAIL $label"
            pass=false
          fi
        }

        check_module "Module registry present" test -f "$ATLAS_MODULE_CONFIG_FILE"
        check_module "Sports compose present" test -f "$ATLAS_PROJECT_DIR/${ATLAS_MODULE_SPORTS_COMPOSE_FILE:-docker-compose.sports.yml}"
        check_module "Sports documentation present" test -f "$ATLAS_PROJECT_DIR/${ATLAS_MODULE_SPORTS_DOC:-docs/SPORTS.md}"
        check_module "Sports config directory present" test -d "$ATLAS_CONFIG_ROOT/sportyfin"
        check_module "Sports media directory present" test -d "$ATLAS_MEDIA_ROOT/Sports"
        check_module "Sports compose valid" docker compose -f docker-compose.yml -f "${ATLAS_MODULE_SPORTS_COMPOSE_FILE:-docker-compose.sports.yml}" config

        echo
        if [ "$pass" = true ]; then
          echo "Sports Module Status: PASS"
        else
          echo "Sports Module Status: FAIL"
          exit 1
        fi
        ;;

      doctor)
        if [[ "$module_name" != "sports" ]]; then
          echo "Usage: atlas module doctor sports"
          exit 1
        fi

        print_header
        echo "Sports Module Doctor"
        echo
        echo "Enabled: ${ATLAS_MODULE_SPORTS_ENABLED:-false}"
        echo

        echo "Files:"
        [[ -f "$ATLAS_PROJECT_DIR/${ATLAS_MODULE_SPORTS_COMPOSE_FILE:-docker-compose.sports.yml}" ]] && echo "  OK docker-compose.sports.yml" || echo "  FAIL docker-compose.sports.yml"
        [[ -f "$ATLAS_PROJECT_DIR/${ATLAS_MODULE_SPORTS_DOC:-docs/SPORTS.md}" ]] && echo "  OK docs/SPORTS.md" || echo "  FAIL docs/SPORTS.md"

        echo
        echo "Directories:"
        [[ -d "$ATLAS_CONFIG_ROOT/sportyfin" ]] && echo "  OK $ATLAS_CONFIG_ROOT/sportyfin" || echo "  FAIL $ATLAS_CONFIG_ROOT/sportyfin"
        [[ -d "$ATLAS_MEDIA_ROOT/Sports" ]] && echo "  OK $ATLAS_MEDIA_ROOT/Sports" || echo "  FAIL $ATLAS_MEDIA_ROOT/Sports"

        echo
        echo "Compose:"
        if docker compose -f docker-compose.yml -f "${ATLAS_MODULE_SPORTS_COMPOSE_FILE:-docker-compose.sports.yml}" config >/dev/null 2>&1; then
          echo "  OK Sports compose valid"
        else
          echo "  FAIL Sports compose invalid"
        fi
        ;;

      *)
        echo "Usage:"
        echo "  atlas module list"
        echo "  atlas module status <module>"
        echo "  atlas module verify <module>"
        echo "  atlas module doctor <module>"
        exit 1
        ;;
    esac
    ;;

  verify)
    print_header
    echo "Atlas Verification"
    echo

    pass=true

    check() {
      label="$1"
      shift
      if "$@" >/dev/null 2>&1; then
        echo "OK   $label"
      else
        echo "FAIL $label"
        pass=false
      fi
    }

    echo "Infrastructure"
    echo "--------------"
    check "Docker Engine" docker info
    check "Docker Compose" docker compose version
    check "Project Directory" test -d "$ATLAS_PROJECT_DIR"
    check "Storage Mounted" test -d "$ATLAS_STORAGE_ROOT"
    check "Intel GPU Available" test -e /dev/dri/renderD128

    echo
    echo "Core Services"
    echo "-------------"
    for service in jellyfin jellyseerr prowlarr sonarr sonarr-anime radarr radarr-anime gluetun qbittorrent homepage; do
      check "$service running" sh -c "docker ps --format '{{.Names}}' | grep -qx '$service'"
    done

    echo
    echo "Storage Paths"
    echo "-------------"
    for path in "$ATLAS_MEDIA_ROOT/Movies" "$ATLAS_MEDIA_ROOT/TV" "$ATLAS_MEDIA_ROOT/Anime Movies" "$ATLAS_MEDIA_ROOT/Anime TV" "$ATLAS_DOWNLOADS_ROOT"; do
      check "$path writable" sh -c "touch '$path/.atlas-test' && rm '$path/.atlas-test'"
    done

    echo
    echo "Project Files"
    echo "-------------"
    for file in VERSION CHARTER.md ROADMAP.md CHANGELOG.md docs/BUILD_LOG.md docs/MATURITY.md docs/INDEXERS.md; do
      check "$file present" test -e "$file"
    done

    echo
    echo "VPN"
    echo "---"
    check "Gluetun running" sh -c "docker ps --format '{{.Names}}' | grep -qx gluetun"
    check "qBittorrent reachable through VPN namespace" docker exec qbittorrent sh -c "curl -s ifconfig.io || wget -qO- ifconfig.io"

    echo
    if [ "$pass" = true ]; then
      echo "Overall Status: PASS"
    else
      echo "Overall Status: FAIL"
      exit 1
    fi
    ;;

  doctor)
    print_header

    echo "Docker:"
    docker info >/dev/null 2>&1 && echo "  OK Docker is running" || echo "  FAIL Docker is not running"

    echo
    echo "Git:"
    if git diff --quiet && git diff --cached --quiet; then
      echo "  OK Working tree clean"
    else
      echo "  WARN Working tree has changes"
    fi

    echo
    echo "VPN:"
    if docker ps --format '{{.Names}}' | grep -qx gluetun; then
      echo "  OK Gluetun container running"
    else
      echo "  FAIL Gluetun container not running"
    fi

    echo
    echo "qBittorrent VPN IP:"
    docker exec qbittorrent sh -c "curl -s ifconfig.io || wget -qO- ifconfig.io" 2>/dev/null || echo "  WARN Could not check qBittorrent public IP"

    echo
    echo "Storage writable:"
    for path in "$ATLAS_MEDIA_ROOT/Movies" "$ATLAS_MEDIA_ROOT/TV" "$ATLAS_MEDIA_ROOT/Anime Movies" "$ATLAS_MEDIA_ROOT/Anime TV" "$ATLAS_DOWNLOADS_ROOT"; do
      if touch "$path/.atlas-write-test" 2>/dev/null; then
        rm -f "$path/.atlas-write-test"
        echo "  OK $path"
      else
        echo "  FAIL $path"
      fi
    done

    echo
    echo "Project Files:"
    for file in VERSION CHARTER.md ROADMAP.md CHANGELOG.md docs/BUILD_LOG.md docs/MATURITY.md; do
      if [ -e "$file" ]; then
        echo "  OK $file"
      else
        echo "  FAIL $file"
      fi
    done

    for dir in docs docs/ADR docs/EDR; do
      if [ -d "$dir" ]; then
        echo "  OK $dir"
      else
        echo "  FAIL $dir"
      fi
    done

    echo
    echo "Container status:"
    docker ps --format "  {{.Names}} - {{.Status}}"
    ;;

  update)
    print_header

    echo "Starting Atlas update..."
    echo

    echo "Pre-update doctor:"
    "$0" doctor

    echo
    echo "Pulling latest container images..."
    docker compose pull

    echo
    echo "Recreating containers..."
    docker compose up -d

    echo
    echo "Cleaning unused images..."
    docker image prune -f

    echo
    echo "Post-update doctor:"
    "$0" doctor

    echo
    echo "Post-update verify:"
    "$0" verify

    echo
    echo "Atlas update complete."
    ;;

  backup)
    print_header

    backup_dir="$ATLAS_BACKUP_DIR"
    mkdir -p "$backup_dir"

    if [ "${2:-}" = "--list" ]; then
      echo "Atlas Backups"
      echo

      if ! ls "$backup_dir"/atlas-*.tar.gz >/dev/null 2>&1; then
        echo "No backups found."
        exit 0
      fi

      ls -1t "$backup_dir"/atlas-*.tar.gz | while read -r file; do
        echo "$(basename "$file")"
        tar -xOzf "$file" BACKUP_INFO.txt 2>/dev/null | sed 's/^/  /' || echo "  No manifest found"
        echo
      done

      exit 0
    fi

    timestamp="$(date +%Y%m%d-%H%M%S-%3N)"
    backup_file="${backup_dir}/atlas-${timestamp}.tar.gz"
    manifest="$(mktemp)"
    notes=""

    if [ "${2:-}" = "--notes" ]; then
      notes="${3:-}"
    fi

    echo "Creating Atlas backup..."
    echo

    cat > "$manifest" <<EOF
Project Atlas Backup

Created: $(date)
Version: $(cat VERSION)
Branch: $(git branch --show-current)
Commit: $(git rev-parse --short HEAD 2>/dev/null || echo unknown)

Notes:
${notes:-None}

EOF

    tar \
      --exclude='.git' \
      --exclude='backups' \
      --transform="s|.*$(basename "$manifest")|BACKUP_INFO.txt|" \
      -czf "$backup_file" \
      docker-compose.yml \
      docker-compose.sports.yml \
      .env.example \
      VERSION \
      CHARTER.md \
      ROADMAP.md \
      CHANGELOG.md \
      config \
      docs \
      modules \
      scripts \
      "$manifest"

    rm -f "$manifest"

    echo "Backup complete"
    echo
    echo "File:"
    echo "  $backup_file"
    echo
    echo "Size:"
    echo "  $(du -h "$backup_file" | awk '{print $1}')"
    echo
    echo "Retention:"
    echo "  Keeping newest 10 backups"

    ls -1t "$backup_dir"/atlas-*.tar.gz 2>/dev/null \
      | tail -n +11 \
      | xargs -r rm -f

    echo
    echo "Status:"
    echo "  SUCCESS"
    ;;

  restart)
    docker compose restart
    ;;

  logs)
    if [ -z "${2:-}" ]; then
      echo "Usage: atlas logs <container>"
      exit 1
    fi
    docker logs "$2" --tail=100 -f
    ;;

  ari)
    "$PROJECT_DIR/scripts/atlas-ari.sh" "${@:2}"
    ;;

  *)
    echo "Unknown command: $command"
    echo "Run: atlas help"
    exit 1
    ;;
esac
